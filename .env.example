# Discord bot token (required)
TOKEN=

# Discord application client ID (required for command deployment)
CLIENT_ID=

# Optional — if set, deploys commands to this guild only (instant). Leave empty for global.
GUILD_ID=

# 64 hex chars (32 bytes). Used to encrypt API keys at rest.
# Generate with: openssl rand -hex 32
# REQUIRED when NODE_ENV=production — startup will fail without it.
ENCRYPTION_KEY=

# Comma-separated Discord user IDs that bypass mod checks in any guild.
MASTER=

# Health endpoint host/port. Defaults bind to localhost only.
# Set HEALTH_HOST=0.0.0.0 to expose on all interfaces (only do this on a private network).
HEALTH_HOST=127.0.0.1
HEALTH_PORT=3000

# Set to "production" on the server. This makes ENCRYPTION_KEY mandatory.
# NODE_ENV=production

# Optional. If set, the weekly leaderboard's shame block is generated by
# Claude (mesugaki カニーちゃん persona). If unset, falls back to the
# static lines in helpers/shame.js.
ANTHROPIC_API_KEY=
